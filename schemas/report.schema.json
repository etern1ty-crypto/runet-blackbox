{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runet-blackbox.example/schemas/report.schema.json",
  "title": "Runet Blackbox Measurement Report",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "tool_version",
    "timestamp_utc",
    "target",
    "country",
    "region",
    "network",
    "results",
    "diagnosis"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "pattern": "^rbb_[a-f0-9]{20}$"
    },
    "schema_version": {
      "const": "1.0"
    },
    "tool_version": {
      "type": "string",
      "minLength": 1
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "target": {
      "type": "string",
      "minLength": 3,
      "maxLength": 253
    },
    "country": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "region": {
      "type": "string",
      "minLength": 1
    },
    "network": {
      "type": "object",
      "required": ["asn", "provider", "connection_type"],
      "properties": {
        "asn": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 4294967295
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "connection_type": {
          "enum": ["unknown", "home", "mobile", "office", "public_wifi", "hosting", "other"]
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "suspected_vpn_or_tunnel": {
          "type": "boolean"
        }
      }
    },
    "results": {
      "type": "object",
      "required": ["dns"],
      "additionalProperties": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {
            "type": "string"
          },
          "latency_ms": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    },
    "diagnosis": {
      "type": "object",
      "required": ["category", "confidence", "signals"],
      "properties": {
        "category": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "signals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
