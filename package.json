{
  "name": "runet-blackbox",
  "version": "0.1.0",
  "description": "Open-source observability for blocked, degraded, and unstable networks.",
  "type": "module",
  "private": false,
  "bin": {
    "runet-blackbox": "./cli/bin/runet-blackbox.js"
  },
  "scripts": {
    "aggregate": "node scripts/aggregate.mjs",
    "check": "node scripts/check-syntax.mjs && npm test",
    "lint": "node scripts/check-syntax.mjs",
    "sample": "node cli/bin/runet-blackbox.js sample --pretty",
    "release:check": "npm run check && node scripts/validate-report.mjs examples/reports/ok.example.json && node cli/bin/runet-blackbox.js sample --pretty",
    "test": "node scripts/run-tests.mjs",
    "test:coverage": "node --test --experimental-test-coverage",
    "validate:sample": "node scripts/validate-report.mjs test/fixtures/valid-report.json"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "runet",
    "observability",
    "censorship-measurement",
    "network-diagnostics",
    "dpi",
    "github-pages"
  ],
  "license": "MIT"
}
